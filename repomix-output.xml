import Link from "next/link";
import { 
  LogOut, User, Search, ShieldCheck, 
  Files, X, Globe, ScanFace, ChevronRight,
  Plane, Calendar, CloudSun, FileText
} from "lucide-react";

export default function Home() {
  const router = useRouter();

