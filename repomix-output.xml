         </div>
      </div>

      {/* 3. KISAYOLLAR & ANA AKSİYON ALANI */}
      <div className="relative z-20 -mt-24 px-6 md:px-12 pb-12">
         <div className="max-w-[1600px] mx-auto">
            
 
