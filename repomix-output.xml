                 <div className={`p-4 rounded-xl transition-transform group-hover:scale-110 ${aktifStatu === 'reddedildi' ? 'bg-red-600 text-white' : 'bg-red-50 text-red-600'}`}><ShieldAlert size={24}/></div>
