                       {aktifStatu === 'bekleyen' && "Sadece bekleyenler filtrelendi."}
                       {aktifStatu === 'cikis_yapti' && "Sadece çıkış yapanlar filtrelendi."}
                       {aktifStatu === 'reddedildi' && "Sadece reddedilen misafirler filtrelendi."}
                    </p>
                 </div>
