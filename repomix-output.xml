                 <div className={`p-4 rounded-xl transition-transform group-hover:scale-110 ${aktifStatu === 'cikis_yapti' ? 'bg-slate-600 text-white' : 'bg-gray-100 text-gray-500'}`}><LogOut size={24}/></div>
