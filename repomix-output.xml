                 <div className={`p-4 rounded-xl transition-transform group-hover:scale-110 ${aktifStatu === 'iceride' ? 'bg-emerald-600 text-white' : 'bg-emerald-50 text-emerald-600'}`}><Activity size={24}/></div>
