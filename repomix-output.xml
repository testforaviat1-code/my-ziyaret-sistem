           </div>
        </div>
      )}

      {/* PERSONEL ROTASYON YÖNETİM MODALI */}
      {showRotasyonModal && (
        <div className="fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-[70] flex items-center justify-center p-4 animate-in fade-in duration-200">
